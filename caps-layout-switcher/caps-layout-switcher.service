[Unit]
Description=CapsLock layout gesture switcher
After=graphical.target

[Service]
Type=simple
ExecStartPre=/usr/bin/modprobe uinput
ExecStart=/home/hugivesafak/scripts/caps-layout-switcher/target/release/caps-layout-switcher --user-uid 1000 --device /dev/input/by-id/usb-_Varmilo-event-kbd
Restart=on-failure
RestartSec=1

[Install]
WantedBy=graphical.target
